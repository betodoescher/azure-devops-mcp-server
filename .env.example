# Azure DevOps Personal Access Token (required)
# Generate at: https://dev.azure.com/{org}/_usersSettings/tokens
# Required permissions: Work Items (Read & Write), Code (Read), Build (Read & Execute), Project and Team (Read)
AZURE_DEVOPS_PAT=your_personal_access_token_here

# Azure DevOps Organization URL (required)
# Default: https://dev.azure.com/ecoagro-tech
AZURE_DEVOPS_ORG=https://dev.azure.com/your-organization

# Azure DevOps REST API version (optional)
# Default: 7.1
AZURE_DEVOPS_API_VERSION=7.1

# Number of days without activity before a PR is considered stale (optional)
# Default: 3
STALE_PR_DAYS=3

# Number of days a work item must be blocked before triggering an alert (optional)
# Default: 2
BLOCKED_ITEM_DAYS=2

# Number of consecutive pipeline failures before triggering an alert (optional)
# Default: 3
FAILING_PIPELINE_THRESHOLD=3
